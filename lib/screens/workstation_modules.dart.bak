                          decoration: const InputDecoration(labelText: 'Location Reference'),
                        ),
                        const SizedBox(height: 12),
                        Row(
                          mainAxisAlignment: MainAxisAlignment.spaceBetween,
                          children: [
                            const Text('Import Data Type:', style: TextStyle(color: Color(0xFF94A3B8), fontSize: 12)),
                            Row(
                              children: [
                                Text('Boreholes', style: TextStyle(color: _isBorehole ? const Color(0xFF14B8A6) : const Color(0xFF64748B), fontSize: 11, fontWeight: FontWeight.bold)),
