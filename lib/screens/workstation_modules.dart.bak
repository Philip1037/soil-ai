  bool _isBorehole = true;
  double _rotationAngle = 0.0; // Dynamic rotation parameter for 3D CustomPainter

  int _boreholeCount = 4;
  int _cptCount = 8;
  int _layerCount = 3;

  void _rotateLeft() {
    setState(() {
      _rotationAngle -= 15.0 * math.pi / 180.0;
    });
  }

  void _rotateRight() {
    setState(() {
      _rotationAngle += 15.0 * math.pi / 180.0;
    });
  }

  void _simulateUpload() {
    setState(() {
      if (_isBorehole) {
        _boreholeCount++;
